POSTGRES_DB=cronmaster
POSTGRES_USER=cronmaster
POSTGRES_PASSWORD=change-this-postgres-password

SESSION_SECRET=change-this-long-random-session-secret
CREDENTIALS_SECRET=change-this-long-random-credentials-secret

# Optional legacy full-access public API key. Prefer creating scoped tokens in the web app.
CRON_MASTER_API_KEY=
DEFAULT_NTFY_SERVER=https://ntfy.sh
CRON_MASTER_BLOCK_PRIVATE_TARGETS=false
CORS_ORIGIN=

API_IMAGE=ghcr.io/OWNER/REPO/api:latest
WEB_IMAGE=ghcr.io/OWNER/REPO/web:latest

API_PORT=4000
WEB_PORT=3001
